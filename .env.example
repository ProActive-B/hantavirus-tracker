# Hetzner deploy target (used by scripts/deploy.sh and .github/workflows/deploy.yml)
HETZNER_HOST=hanta.example.com
HETZNER_USER=deploy
HETZNER_PATH=/var/www/hantavirus

# EthicalAds publisher id (optional; site renders without it)
ETHICALADS_PUBLISHER=

# ProMED-mail credentials (only if private feed; public RSS needs none)
PROMED_USER=
PROMED_PASS=
