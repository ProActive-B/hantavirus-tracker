---
import 'maplibre-gl/dist/maplibre-gl.css';
import ConfidenceLegend from './ConfidenceLegend.astro';
---
<section class="grid grid-cols-1 gap-4 lg:grid-cols-[1fr_22rem]">
  <div class="relative overflow-hidden rounded-lg border border-ink/10 bg-white shadow-sm">
    <div id="hanta-map" class="h-[70vh] w-full"></div>
    <div class="absolute left-3 top-3 z-10 rounded-md bg-white/95 px-3 py-2 shadow ring-1 ring-ink/5">
      <ConfidenceLegend />
    </div>
  </div>

  <aside id="hanta-panel" class="rounded-lg border border-ink/10 bg-white p-4 shadow-sm text-sm">
    <h2 class="text-base font-semibold">Select a point</h2>
    <p class="mt-1 text-ink/60">Click a marker on the map for incident details, source, and last-updated timestamp.</p>
    <div id="hanta-panel-body" class="mt-4 space-y-3"></div>
  </aside>
</section>

<script>
  import maplibregl from 'maplibre-gl';

  const COLORS: Record<string, string> = {
    confirmed: '#b91c1c',
    probable: '#d97706',
    signal: '#475569',
  };

  type Feature = {
    type: 'Feature';
    geometry: { type: 'Point'; coordinates: [number, number] };
    properties: {
      id: string;
      title: string;
      location: string;
      cases?: number;
      deaths?: number;
      confidence: 'confirmed' | 'probable' | 'signal';
      virus: string;
      reported: string;
      source_name: string;
      source_url: string;
      summary: string;
    };
  };

  async function init() {
    const resp = await fetch('/data/hantavirus.geojson', { cache: 'no-store' });
    const data: { features: Feature[] } = await resp.json();

    const map = new maplibregl.Map({
      container: 'hanta-map',
      style: 'https://tiles.openfreemap.org/styles/positron',
      center: [-30, 20],
      zoom: 1.8,
      attributionControl: { compact: true },
    });

    map.addControl(new maplibregl.NavigationControl({ showCompass: false }), 'top-right');

    map.on('load', () => {
      map.addSource('hanta', { type: 'geojson', data: data as any });

      map.addLayer({
        id: 'hanta-circles',
        type: 'circle',
        source: 'hanta',
        paint: {
          'circle-radius': [
            'interpolate', ['linear'], ['coalesce', ['get', 'cases'], 1],
            1, 5,
            10, 8,
            100, 14,
            1000, 22,
          ],
          'circle-color': [
            'match', ['get', 'confidence'],
            'confirmed', COLORS.confirmed,
            'probable', COLORS.probable,
            'signal', COLORS.signal,
            '#475569',
          ],
          'circle-opacity': 0.75,
          'circle-stroke-width': 1.5,
          'circle-stroke-color': '#fff',
        },
      });

      map.on('click', 'hanta-circles', (e) => {
        const f = e.features?.[0] as unknown as Feature | undefined;
        if (!f) return;
        renderPanel(f);
        map.flyTo({ center: f.geometry.coordinates, zoom: Math.max(map.getZoom(), 3.5) });
      });

      map.on('mouseenter', 'hanta-circles', () => { map.getCanvas().style.cursor = 'pointer'; });
      map.on('mouseleave', 'hanta-circles', () => { map.getCanvas().style.cursor = ''; });

      // pre-load first feature in side panel so panel isn't empty on first paint
      if (data.features.length) renderPanel(data.features[0]);
    });
  }

  function renderPanel(f: any) {
    const p = f.properties;
    const el = document.getElementById('hanta-panel-body');
    if (!el) return;
    el.innerHTML = `
      <div class="space-y-1">
        <div class="flex items-center gap-2">
          <span class="confidence-dot ${p.confidence}"></span>
          <span class="text-xs uppercase tracking-wide text-ink/60">${p.confidence}</span>
        </div>
        <h3 class="text-base font-semibold leading-snug">${p.title}</h3>
        <div class="text-ink/70">${p.location}</div>
      </div>
      <dl class="grid grid-cols-2 gap-x-3 gap-y-1 text-sm">
        <dt class="text-ink/50">Virus</dt><dd>${p.virus}</dd>
        ${p.cases != null ? `<dt class="text-ink/50">Cases</dt><dd>${p.cases}</dd>` : ''}
        ${p.deaths != null ? `<dt class="text-ink/50">Deaths</dt><dd>${p.deaths}</dd>` : ''}
        <dt class="text-ink/50">Reported</dt><dd>${p.reported}</dd>
      </dl>
      <p class="text-ink/80">${p.summary}</p>
      <a href="${p.source_url}" target="_blank" rel="noopener" class="inline-block text-accent underline decoration-dotted hover:text-accent/80">
        ${p.source_name} →
      </a>
    `;
  }

  init().catch((err) => {
    console.error(err);
    const el = document.getElementById('hanta-panel-body');
    if (el) el.textContent = 'Failed to load incident data.';
  });
</script>
